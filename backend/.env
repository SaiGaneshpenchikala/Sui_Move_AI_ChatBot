TREASURY_CAP_OBJECT_ID=
MINT_CAP_OBJECT_ID=
POINTS_ADMIN_CAP_OBJECT_ID=
ADMIN_CAP_OBJECT_ID=
# Server
PORT=3001
FRONTEND_URL=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
