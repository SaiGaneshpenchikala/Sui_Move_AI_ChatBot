# Anthropic API
ANTHROPIC_API_KEY=
# Sui Configuration
SUI_NETWORK=testnet
# AI service wallet private key (hex) — holds MintCap, PointsAdminCap, AdminCap
AI_SERVICE_PRIVATE_KEY= 
# Deployed contract package ID
PACKAGE_ID=  
# Object IDs from deployment
